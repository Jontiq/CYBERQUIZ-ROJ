@page
@model CYBERQUIZ.UI.Pages.QuizPages.QuizHomeModel
@{
    ViewData["Title"] = "Quiz";
}
<h2>Kategorier</h2>

@foreach (var category in Model.Categories)
{
    <div style="margin-bottom: 20px;">
        <h3>@category.Name</h3>
        @foreach (var sub in category.SubCategories)
        {
            <div style="margin-bottom: 8px;">
                @if (sub.ProgressPercent < 0)
                {
                    <span>⬜ @sub.Name (@sub.QuestionCount frågor) - Ej påbörjad</span>
                }
                else if (sub.ProgressPercent >= 80)
                {
                    <span>✅ @sub.Name (@sub.QuestionCount frågor) - Godkänd (@sub.ProgressPercent.ToString("F0")%)</span>
                }
                else
                {
                    <span>❌ @sub.Name (@sub.QuestionCount frågor) - Ej godkänd (@sub.ProgressPercent.ToString("F0")%)</span>
                }

                @if (sub.IsUnlocked)
                {
                    <a asp-page="/QuizPages/QuestionPages/QuizQuestion"
                       asp-route-subCategoryId="@sub.Id">
                        <button>Starta quiz</button>
                    </a>
                }
                else
                {
                    <span>🔒</span>
                }
            </div>
        }
    </div>
}