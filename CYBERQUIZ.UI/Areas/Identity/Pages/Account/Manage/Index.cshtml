@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">

        @* Visa progressionsdata om den finns *@
        @if (Model.Progress != null)
        {
            @* Total progressionsbar för hela quizet *@
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Total progression</h5>
                    <p>@Model.Progress.AnsweredCorrectly av @Model.Progress.TotalQuestions frågor rätt</p>
                    <div class="progress">
                        <div class="progress-bar bg-success"
                             role="progressbar"
                             style="width: @Model.Progress.OverallPercent.ToString("F0")%"
                             aria-valuenow="@Model.Progress.OverallPercent.ToString("F0")"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @Model.Progress.OverallPercent.ToString("F0")%
                        </div>
                    </div>
                </div>
            </div>

            @* AI Feedback-sektion *@
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">AI-feedback</h5>

                    <form method="post" asp-page-handler="LoadFeedback">
                        <button type="submit" class="btn btn-primary mb-3">Ladda feedback</button>
                    </form>

                    @if (Model.AiCoach != null)
                    {
                        @* Visa felaktiga frågor numrerade *@
                        @if (!string.IsNullOrEmpty(Model.AiCoach.QuestionText))
                        {
                            <h6 class="mt-2">Frågor du behöver öva på:</h6>
                            <ol>
                                @foreach (var question in Model.AiCoach.QuestionText.Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
                                {
                                    var parts = question.Split('\n');
                                    <li class="mb-2">
                                        @parts[0]
                                        @if (parts.Length > 1)
                                        {
                                            <br />
                                            <small class="text-muted">@parts[1]</small>
                                        }
                                    </li>
                                }
                            </ol>
                        }

                        @* AI:ns samlade rekommendation *@
                        <div class="mt-3 p-3 bg-light rounded border-start border-primary border-3">
                            <h6>💡 Studieråd från AI-coachen:</h6>
                            <p class="mb-0">@Model.AiCoach.AiRecommendation</p>
                        </div>
                    }
                </div>
            </div>
            

            @* En card per subkategori med individuell progressionsbar *@
            <h5>Progression per påbörjad subkategori</h5>
            @foreach (var sub in Model.Progress.SubCategoryProgress)
            {
                <div class="card mb-2">
                    <div class="card-body">
                        @* Rubrik med subkategorinamn och godkänd/ej godkänd-badge *@
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <strong>@sub.SubCategoryName</strong>
                            @if (sub.Passed)
                            {
                                <span class="badge bg-success">Godkänd ✓</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Ej godkänd</span>
                            }
                        </div>
                        @* Antal rätt av totalt *@
                        <p class="mb-1 text-muted">@sub.Correct av @sub.Total rätt</p>
                        @* Progressionsbar, grön om godkänd annars gul *@
                        <div class="progress">
                            <div class="progress-bar @(sub.Passed ? "bg-success" : "bg-warning")"
                                 role="progressbar"
                                 style="width: @sub.Percent.ToString("F0")%"
                                 aria-valuenow="@sub.Percent.ToString("F0")"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                                @sub.Percent.ToString("F0")%
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            @* Visas om ingen progressionsdata finns tillgänglig *@
            <p class="text-muted">Ingen progressionsdata hittades.</p>
        }

    </div>
</div>